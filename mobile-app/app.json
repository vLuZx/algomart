{
  "expo": {
    "name": "Algomart",
    "slug": "algomart",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "algomart",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.algomart.app"
    },
    "android": {
      "package": "com.algomart.app"
    },
    "plugins": [
      "expo-router",
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "Algomart needs access to your camera to scan product barcodes.",
          "enableCodeScanner": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
